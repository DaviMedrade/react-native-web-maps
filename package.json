{
	"name": "react-native-web-maps",
	"version": "0.1.0",
	"description": "Web implementation of the react-native-maps API for react-native-web, using the Google Maps JS API",
	"author": "Davi Medrade <davi@medrade.com.br>",
	"license": "MIT",
	"main": "dist/commonjs/index.web.js",
	"module": "dist/module/index.web.js",
	"types": "dist/typescript/index.web.d.ts",
	"react-native": "src/index",
	"source": "src/index",
	"files": [
		"src",
		"dist",
		"!**/__tests__"
	],
	"scripts": {
		"build": "npm run build:cjs && npm run build:esm",
		"build:cjs": "tsc -p tsconfig.build-cjs.json",
		"build:esm": "tsc -p tsconfig.build-esm.json",
		"format": "prettier --write .",
		"lint": "eslint .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"prepare": "npm run build"
	},
	"peerDependencies": {
		"@react-google-maps/api": ">=2.19.0",
		"react": ">=18",
		"react-native": ">=0.72",
		"react-native-maps": ">=1.3.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@react-google-maps/api": "^2.20.8",
		"@types/google.maps": "^3.65.3",
		"@types/react": "^19.2.17",
		"@vitest/browser": "^4.1.10",
		"@vitest/browser-playwright": "^4.1.10",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-react-hooks": "^7.1.1",
		"playwright": "^1.61.1",
		"prettier": "^3.9.6",
		"react": "^19.2.8",
		"react-dom": "^19.2.8",
		"react-native": "^0.86.0",
		"react-native-maps": "^1.29.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.65.0",
		"vitest": "^4.1.10",
		"vitest-browser-react": "^2.2.0"
	}
}
